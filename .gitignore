# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pycache
*.egg
*.egg-info/
dist/
build/
*.spec

# ──────────────────────────────────────────────────────────────────────────────
# Virtual Environments
# ──────────────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env

# ──────────────────────────────────────────────────────────────────────────────
# Model Weights & Large Binary Files
# GitHub has a 100 MB file size limit and 2 GB repo limit.
# Use Git LFS or download scripts instead.
# ──────────────────────────────────────────────────────────────────────────────
models/weights/
models/seatbelt_classifier/
*.pt
*.pth
*.onnx
*.engine
*.tflite
*.pb
*.h5
*.pkl
*.bin
*.safetensors

# ──────────────────────────────────────────────────────────────────────────────
# Raw Video / Image Data (large files)
# ──────────────────────────────────────────────────────────────────────────────
data/raw/
data/seatbelt_crops/
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# ──────────────────────────────────────────────────────────────────────────────
# Runtime Artifacts (generated by the pipeline)
# ──────────────────────────────────────────────────────────────────────────────
artifacts/evidence/
artifacts/*.db
artifacts/*.log
artifacts/*.csv
artifacts/export.csv

# SQLite runtime sidecar files
*.db-journal
*.db-wal
*.db-shm

# ──────────────────────────────────────────────────────────────────────────────
# Jupyter Notebooks — output cells & checkpoints
# ──────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ──────────────────────────────────────────────────────────────────────────────
# PaddleOCR / PaddlePaddle inference model cache
# ──────────────────────────────────────────────────────────────────────────────
inference/
paddle_infer/
*.pdmodel
*.pdiparams
*.pdparams

# ──────────────────────────────────────────────────────────────────────────────
# PyTorch / Ultralytics cache
# ──────────────────────────────────────────────────────────────────────────────
runs/
ultralytics/
*.cache
datasets/

# ──────────────────────────────────────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ──────────────────────────────────────────────────────────────────────────────
# OS Generated
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────────────────────────────────────
# Secrets / Config Overrides (never commit these)
# ──────────────────────────────────────────────────────────────────────────────
*.secret
.env.local
.env.production
secrets.yaml
secrets.json

# ──────────────────────────────────────────────────────────────────────────────
# Test / Coverage output
# ──────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
